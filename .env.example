# ----- Edu Seria LMS configuration -----
# Copy this file to ".env" and fill in values.

# Which database driver to use:
#   "sqlite" (local demo) | "mssql" (Azure SQL) | "oracle" (Oracle Autonomous DB)
DB_CLIENT=sqlite

# Secret used to sign JWTs. Use a long random string in production.
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES=8h

# Port (Azure App Service sets this automatically)
PORT=3000

# ----- Local SQLite (only used when DB_CLIENT=sqlite) -----
# SQLITE_FILE=./data.sqlite

# ----- Azure SQL Database (only used when DB_CLIENT=mssql) -----
# AZURE_SQL_SERVER=eduseria-sql.database.windows.net
# AZURE_SQL_DATABASE=eduseria_lms
# AZURE_SQL_USER=eduseriaadmin
# AZURE_SQL_PASSWORD=YourStrong!Passw0rd
# AZURE_SQL_PORT=1433

# ----- Oracle Autonomous Database (only used when DB_CLIENT=oracle) -----
# ORACLE_USER=ADMIN
# ORACLE_PASSWORD=YourADBadminPassword
# ORACLE_CONNECT_STRING=eduseriadb_tp        # a tns alias from the wallet's tnsnames.ora
# ORACLE_WALLET_DIR=./wallet                 # folder where you unzipped the wallet
# ORACLE_WALLET_PASSWORD=YourWalletPassword  # the password you set when downloading the wallet
